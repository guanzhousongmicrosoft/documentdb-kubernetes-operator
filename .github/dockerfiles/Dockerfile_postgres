# DocumentDB extension image for CNPG ImageVolume mode.
# Contains only the DocumentDB extension artifacts and their runtime
# dependencies — PostgreSQL itself is provided by the CNPG base image.
#
# Usage:
#   docker build \
#     --build-arg POSTGRES_VERSION=18 \
#     --build-arg DEB_PACKAGE_REL_PATH=packages/deb13-postgresql-18-documentdb_X.Y.Z_arm64.deb \
#     -t documentdb-extension:latest \
#     -f Dockerfile_postgres .
ARG BASE_IMAGE=debian:trixie-slim
FROM ${BASE_IMAGE}

ARG DEBIAN_FRONTEND=noninteractive
ARG POSTGRES_VERSION=18
# Required: path (relative to build context) to a pre-built DocumentDB .deb.
ARG DEB_PACKAGE_REL_PATH

# Fail fast when the caller forgets the deb path.
RUN [ -n "${DEB_PACKAGE_REL_PATH}" ] || \
    (echo "ERROR: DEB_PACKAGE_REL_PATH build-arg is required." >&2; exit 1)

# ---------- pgdg repo (for pg_cron, pgvector, postgis packages) ----------
RUN apt-get update; \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        gnupg2 \
        lsb-release \
        wget; \
    install -d -m 0755 /etc/apt/keyrings; \
    wget -qO /etc/apt/keyrings/pgdg.asc \
        https://www.postgresql.org/media/keys/ACCC4CF8.asc; \
    echo "deb [signed-by=/etc/apt/keyrings/pgdg.asc] \
        http://apt.postgresql.org/pub/repos/apt \
        $(lsb_release -cs)-pgdg main ${POSTGRES_VERSION}" \
        > /etc/apt/sources.list.d/pgdg.list; \
    apt-get update; \
    # Install extension packages without pulling in full PostgreSQL server.
    # These debs depend on postgresql-NN, which is already in the CNPG base
    # image at runtime, so we skip the dependency check here.
    apt-get download \
        postgresql-${POSTGRES_VERSION}-cron \
        postgresql-${POSTGRES_VERSION}-pgvector \
        postgresql-${POSTGRES_VERSION}-postgis-3; \
    dpkg --force-depends -i ./*.deb; \
    rm -f ./*.deb; \
    # Install runtime shared-library dependencies that the extensions need.
    apt-get install -y --no-install-recommends -f; \
    # Remove build-only tools
    apt-get purge -y --auto-remove ca-certificates gnupg2 lsb-release wget; \
    apt-get clean; \
    rm -rf /var/lib/apt/lists/*

# ---------- DocumentDB extension ----------
COPY ${DEB_PACKAGE_REL_PATH} /tmp/documentdb.deb
RUN dpkg --force-depends -i /tmp/documentdb.deb; \
    rm -f /tmp/documentdb.deb; \
    # Install any missing runtime dependencies for the DocumentDB extension.
    apt-get update; \
    apt-get install -y --no-install-recommends -f; \
    apt-get clean; \
    rm -rf /var/lib/apt/lists/*; \
    # Resolve Debian-alternatives symlinks that break when the image is \
    # mounted as a CNPG ImageVolume (the /etc/alternatives/ target is \
    # outside the volume mount).  Replace each dangling symlink with a \
    # copy of the file it ultimately points to. \
    for link in \
      /usr/share/postgresql/${POSTGRES_VERSION}/extension/*.control \
      /usr/share/postgresql/${POSTGRES_VERSION}/extension/*.sql \
      /usr/lib/postgresql/${POSTGRES_VERSION}/lib/*.so; do \
        [ -L "$link" ] || continue; \
        target=$(readlink -f "$link" 2>/dev/null); \
        if [ -n "$target" ] && [ -f "$target" ]; then \
            cp --remove-destination "$target" "$link"; \
        elif [ -L "$link" ] && [ ! -e "$link" ]; then \
            rm -f "$link"; \
        fi; \
    done
